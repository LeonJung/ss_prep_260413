<?xml version="1.0"?>
<!--
  UR3e MJCF model with high-fidelity meshes from SouthColumn76's
  menagerie-compatible UR3e conversion
  (https://github.com/SouthColumn76/universal_robots_ur3e/).  Mesh files are
  OBJ, same multi-part naming scheme as menagerie UR10e/UR5e, placed in
  assets/ur3e/.

  Patches relative to the upstream SouthColumn76 ur3e.xml — mirrors the
  exact patch set applied to ur10e.xml so that leader_sim.py / follower_sim.py
  / ROBOT_BODIES / eef-site / actuator-name conventions stay identical
  across the two leader robots:

    * The root body is renamed "base" → "base_link".
    * The base body gets quat="0 0 0 -1" (180° Z) so that its world-frame
      orientation matches the ur10e.xml convention — both robots face the
      same direction in their respective MuJoCo windows at home pose.
    * An empty "flange" body is added as a fixed child of wrist_3_link
      with the "eef" site (formerly "attachment_site") inside it.
    * The upstream <general> position-servo actuators are replaced with
      <motor> torque actuators (gear=1, a_* prefix, ctrlrange = UR3e
      official peak torques 54/54/28/9/9/9 Nm).
    * A floor geom and two lights are included inline so ur3e.xml is a
      self-contained scene.
    * Explicit timestep=0.002 on <option>.
    * Keyframe ctrl zeroed (position-servo values don't apply to torque).
    * Joint damping added to the size2/size1/size0 defaults so the motor
      actuators have a stable physical plant to drive.
-->
<mujoco model="ur3e">
  <compiler angle="radian" meshdir="../assets/ur3e" autolimits="true"/>

  <option timestep="0.002" integrator="implicitfast"/>

  <default>
    <default class="ur3e">
      <material specular="0.5" shininess="0.25"/>
      <joint axis="0 1 0" range="-6.28319 6.28319" armature="0.1"/>
      <default class="size2">
        <joint damping="5"/>
      </default>
      <default class="size1">
        <joint damping="3"/>
        <default class="size1_limited">
          <joint range="-3.14159 3.14159"/>
        </default>
      </default>
      <default class="size0">
        <joint damping="1"/>
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom type="capsule" group="3"/>
        <default class="eef_collision">
          <geom type="cylinder"/>
        </default>
      </default>
      <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4"/>
    </default>
  </default>

  <asset>
    <material class="ur3e" name="black"     rgba="0.033 0.033 0.033 1"/>
    <material class="ur3e" name="jointgray" rgba="0.278 0.278 0.278 1"/>
    <material class="ur3e" name="linkgray"  rgba="0.82 0.82 0.82 1"/>
    <material class="ur3e" name="urblue"    rgba="0.49 0.678 0.8 1"/>

    <texture type="skybox" builtin="gradient"
             rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.2"/>

    <mesh file="base_0.obj"/>
    <mesh file="base_1.obj"/>
    <mesh file="shoulder_0.obj"/>
    <mesh file="shoulder_1.obj"/>
    <mesh file="shoulder_2.obj"/>
    <mesh file="upperarm_0.obj"/>
    <mesh file="upperarm_1.obj"/>
    <mesh file="upperarm_2.obj"/>
    <mesh file="upperarm_3.obj"/>
    <mesh file="forearm_0.obj"/>
    <mesh file="forearm_1.obj"/>
    <mesh file="forearm_2.obj"/>
    <mesh file="forearm_3.obj"/>
    <mesh file="wrist1_0.obj"/>
    <mesh file="wrist1_1.obj"/>
    <mesh file="wrist1_2.obj"/>
    <mesh file="wrist2_0.obj"/>
    <mesh file="wrist2_1.obj"/>
    <mesh file="wrist2_2.obj"/>
    <mesh file="wrist3.obj"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <light name="spotlight" mode="targetbodycom" target="wrist_2_link" pos="0 -1 2"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <body name="base_link" quat="0 0 0 -1" childclass="ur3e">
      <inertial mass="2" pos="0 0 0" diaginertia="0.0030532 0.0030532 0.005625"/>
      <geom mesh="base_0" material="jointgray" class="visual"/>
      <geom mesh="base_1" material="black"     class="visual"/>
      <body name="shoulder_link" pos="0 0 0.152">
        <inertial mass="2" pos="0 0 0"
                  diaginertia="0.00809316 0.00809316 0.005625"/>
        <joint name="shoulder_pan_joint" class="size2" axis="0 0 1"/>
        <geom mesh="shoulder_0" material="urblue"    class="visual"/>
        <geom mesh="shoulder_1" material="black"     class="visual"/>
        <geom mesh="shoulder_2" material="jointgray" class="visual"/>
        <geom class="collision" size="0.047 0.05" pos="0 0 -0.032"/>
        <body name="upper_arm_link" pos="0 0.12 0" quat="1 0 1 0">
          <inertial mass="3.42" pos="0 0 0.122"
                    diaginertia="0.0217285 0.0217285 0.00961875"/>
          <joint name="shoulder_lift_joint" class="size2"/>
          <geom mesh="upperarm_0" material="black"     class="visual"/>
          <geom mesh="upperarm_1" material="urblue"    class="visual"/>
          <geom mesh="upperarm_2" material="jointgray" class="visual"/>
          <geom mesh="upperarm_3" material="linkgray"  class="visual"/>
          <geom class="collision" size="0.046 0.06" pos="0 -0.04 0" quat="1 1 0 0"/>
          <geom class="collision" size="0.038 0.11" pos="0 0 0.12"/>
          <body name="forearm_link" pos="0 -0.093 0.244">
            <inertial mass="1.26" pos="0 0 0.10625"
                      diaginertia="0.00654457 0.00654457 0.00354375"/>
            <joint name="elbow_joint" class="size1_limited"/>
            <geom mesh="forearm_0" material="urblue"    class="visual"/>
            <geom mesh="forearm_1" material="linkgray"  class="visual"/>
            <geom mesh="forearm_2" material="black"     class="visual"/>
            <geom mesh="forearm_3" material="jointgray" class="visual"/>
            <geom class="collision" size="0.038 0.048" pos="0 0.062 0" quat="1 1 0 0"/>
            <geom class="collision" size="0.032 0.103" pos="0 0 0.11"/>
            <body name="wrist_1_link" pos="0.0005 0 0.2125" quat="1 0 1 0">
              <inertial mass="0.8" pos="0 0.104 0"
                        diaginertia="0.00225 0.002085 0.002085"/>
              <joint name="wrist_1_joint" class="size0"/>
              <geom mesh="wrist1_0" material="jointgray" class="visual"/>
              <geom mesh="wrist1_1" material="urblue"    class="visual"/>
              <geom mesh="wrist1_2" material="black"     class="visual"/>
              <geom class="collision" size="0.032 0.05" pos="0 0.045 0" quat="1 1 0 0"/>
              <body name="wrist_2_link" pos="0 0.104 0">
                <inertial mass="0.8" pos="0 0 0.085"
                          diaginertia="0.00225 0.002085 0.002085"/>
                <joint name="wrist_2_joint" axis="0 0 1" class="size0"/>
                <geom mesh="wrist2_0" material="jointgray" class="visual"/>
                <geom mesh="wrist2_1" material="black"     class="visual"/>
                <geom mesh="wrist2_2" material="urblue"    class="visual"/>
                <geom class="collision" size="0.032 0.05" pos="0 0 0.035"/>
                <geom class="collision" size="0.032 0.027" pos="0 0.01 0.085" quat="1 1 0 0"/>
                <body name="wrist_3_link" pos="0 0 0.085">
                  <inertial mass="0.35" pos="0 0.0715 0" quat="1 0 0 1"
                            diaginertia="0.0001792 0.000136267 0.000136267"/>
                  <joint name="wrist_3_joint" class="size0"/>
                  <geom material="linkgray" mesh="wrist3" class="visual"/>
                  <geom class="eef_collision" size="0.032 0.023" pos="0 0.07 0" quat="1 1 0 0"/>

                  <!-- Empty flange body hosting the eef site (mirrors ur10e.xml) -->
                  <body name="flange" pos="0 0 0">
                    <site name="eef" pos="0 0.09215 0" quat="-1 1 0 0"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Pure-torque actuators.  ctrlrange values are the official UR3e peak
       torques from UniversalRobots ROS2 description (54/28/9 Nm). -->
  <actuator>
    <motor name="a_shoulder_pan"  joint="shoulder_pan_joint"
           gear="1" ctrllimited="true" ctrlrange="-54 54"/>
    <motor name="a_shoulder_lift" joint="shoulder_lift_joint"
           gear="1" ctrllimited="true" ctrlrange="-54 54"/>
    <motor name="a_elbow"         joint="elbow_joint"
           gear="1" ctrllimited="true" ctrlrange="-28 28"/>
    <motor name="a_wrist_1"       joint="wrist_1_joint"
           gear="1" ctrllimited="true" ctrlrange="-9 9"/>
    <motor name="a_wrist_2"       joint="wrist_2_joint"
           gear="1" ctrllimited="true" ctrlrange="-9 9"/>
    <motor name="a_wrist_3"       joint="wrist_3_joint"
           gear="1" ctrllimited="true" ctrlrange="-9 9"/>
  </actuator>

  <keyframe>
    <key name="home"
         qpos="-1.5708 -1.5708 1.5708 -1.5708 -1.5708 0"
         ctrl="0 0 0 0 0 0"/>
  </keyframe>
</mujoco>
